{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "users": {
      "$uid": {
        // Allow users to read/write only their own data
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        
        "flashcards": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          "$cardId": {
            // Validate flashcard data structure
            ".validate": "newData.hasChildren(['front', 'back', 'created_at'])",
            "front": { ".validate": "newData.isString()" },
            "back": { ".validate": "newData.isString()" },
            "created_at": { ".validate": "newData.isNumber()" }
          }
        },
        
        "progress": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          "$progressId": {
            ".validate": "newData.hasChildren(['card_id', 'last_reviewed', 'next_review', 'ease_factor'])",
            "card_id": { ".validate": "newData.isString()" },
            "last_reviewed": { ".validate": "newData.isNumber()" },
            "next_review": { ".validate": "newData.isNumber()" },
            "ease_factor": { ".validate": "newData.isNumber()" }
          }
        }
      }
    },
    
    "shared_decks": {
      ".read": "auth != null",
      "$deckId": {
        ".write": "auth != null && (!data.exists() || data.child('creator_uid').val() === auth.uid)",
        ".validate": "newData.hasChildren(['title', 'creator_uid', 'created_at'])"
      }
    }
  }
}
