{
  "rules": {
    "users": {
      "$uid": {
        // Users can only read and write their own data
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        // Validate user profile data
        ".validate": "newData.hasChildren(['email', 'username', 'createdAt'])",
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$/)"
        },
        "username": {
          ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 30"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        }
      }
    },
    
    "flashcards": {
      ".read": "auth !== null",
      "$cardId": {
        // Only authenticated users can create/update cards
        ".write": "auth !== null",
        
        // Validate flashcard data
        ".validate": "newData.hasChildren(['front', 'back', 'deckId', 'userId', 'createdAt'])",
        "front": {
          ".validate": "newData.isString() && newData.val().length <= 1000"
        },
        "back": {
          ".validate": "newData.isString() && newData.val().length <= 1000"
        },
        "deckId": {
          ".validate": "newData.isString() && root.child('decks').child(newData.val()).exists()"
        },
        "userId": {
          ".validate": "newData.val() === auth.uid"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },
        "tags": {
          ".validate": "!newData.exists() || (newData.isArray() && newData.val().length <= 10)"
        }
      }
    },
    
    "decks": {
      ".read": "auth !== null",
      "$deckId": {
        // Only deck owners can modify decks
        ".write": "auth !== null && (!data.exists() || data.child('userId').val() === auth.uid)",
        
        // Validate deck data
        ".validate": "newData.hasChildren(['name', 'userId', 'createdAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "description": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)"
        },
        "userId": {
          ".validate": "newData.val() === auth.uid"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        }
      }
    },
    
    "progress": {
      "$uid": {
        // Users can only access their own progress
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        "$cardId": {
          // Validate progress data
          ".validate": "newData.hasChildren(['lastReviewed', 'nextReview', 'easeFactor'])",
          "lastReviewed": {
            ".validate": "newData.isNumber() && newData.val() <= now"
          },
          "nextReview": {
            ".validate": "newData.isNumber() && newData.val() >= now"
          },
          "easeFactor": {
            ".validate": "newData.isNumber() && newData.val() >= 1.3 && newData.val() <= 2.5"
          },
          "quality": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"
          }
        }
      }
    },
    
    "user_settings": {
      "$uid": {
        // Users can only access their own settings
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        // Validate settings data
        "theme": {
          ".validate": "!newData.exists() || newData.val() === 'light' || newData.val() === 'dark'"
        },
        "notifications": {
          ".validate": "!newData.exists() || newData.isBoolean()"
        },
        "studyReminders": {
          "enabled": {
            ".validate": "!newData.exists() || newData.isBoolean()"
          },
          "time": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^([01]?[0-9]|2[0-3]):[0-5][0-9]$/))"
          }
        }
      }
    }
  }
}
